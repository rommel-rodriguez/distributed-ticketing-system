    "start": "ts-node-dev --poll src/index.ts",
    "test": "npm run test:ci:fast",
    "test:unit": "jest --config jest.unit.config.js --runInBand --watchAll=false --passWithNoTests",
    "test:integration": "jest --config jest.integration.config.js --runInBand --watchAll=false --passWithNoTests",
    "test:system": "jest --config jest.system.config.js --runInBand --watchAll=false --passWithNoTests",
